diff --git a/benchmarks/000.microbenchmarks/040.server-reply/nodejs/function.js b/benchmarks/000.microbenchmarks/040.server-reply/nodejs/function.js
new file mode 100644
index 00000000..d1a166d5
--- /dev/null
+++ b/benchmarks/000.microbenchmarks/040.server-reply/nodejs/function.js
@@ -0,0 +1,20 @@
+// Copyright 2020-2025 ETH Zurich and the SeBS authors. All rights reserved.
+const net = require('net');
+
+exports.handler = async function(event) {
+  const host = event['ip-address'];
+  const port = event['port'];
+  return new Promise((resolve, reject) => {
+    const socket = net.createConnection({host, port});
+    socket.setTimeout(20000);
+    socket.on('data', (data) => {
+      socket.end();
+      resolve({result: data.toString()});
+    });
+    socket.on('timeout', () => {
+      socket.destroy();
+      reject(new Error('server-reply timeout'));
+    });
+    socket.on('error', reject);
+  });
+};
